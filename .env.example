# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL (used in LINE Flex Message links)
NEXT_PUBLIC_SITE_URL=https://marlafilmlab.com

# Environment label — set to "production" for production tables (orders, customers, etc.)
NEXT_PUBLIC_APP_ENV=production

# Admin dashboard password (server-side only)
ADMIN_BETA_PASSWORD=

# LINE Official Account / LIFF
NEXT_PUBLIC_LIFF_ID=
NEXT_PUBLIC_LINE_OA_ID=
NEXT_PUBLIC_LINE_OA_URL=

# LINE Messaging API (server-only — never expose to the browser)
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
