# Supabase (Beta project only — do NOT use production)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# Environment label — set to "beta" for beta tables (beta_orders, beta_customers, etc.)
NEXT_PUBLIC_APP_ENV=beta

# Admin dashboard password (server-side only)
ADMIN_BETA_PASSWORD=
